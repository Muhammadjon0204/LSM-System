@page
@model RazorPages.Pages.Auth.ResetPasswordModel
@{
    ViewData["Title"] = "Сброс пароля";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

@section Styles {
<style>
.auth-wrap {
    min-height: calc(100vh - var(--nav-h) - 80px);
    display: flex; align-items: center; justify-content: center;
}
.auth-box { width: 100%; max-width: 420px; }
.auth-title {
    font-family: var(--font-head);
    font-size: 1.85rem; font-weight: 800;
    letter-spacing: -0.04em; margin-bottom: 0.4rem;
    text-align: center;
}
.auth-sub { color: var(--muted); font-size: 0.9rem; text-align: center; }

/* Code input */
.code-inputs {
    display: flex; gap: 0.6rem; justify-content: center;
    margin: 0.5rem 0;
}
.code-digit {
    width: 52px; height: 60px;
    text-align: center;
    font-family: var(--font-head);
    font-size: 1.5rem; font-weight: 700;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--text);
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    caret-color: var(--accent);
}
.code-digit:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(108,99,255,0.15);
}
.code-digit.filled { border-color: rgba(108,99,255,0.4); }

.password-wrapper { position: relative; }
.password-toggle {
    position: absolute; right: 0.75rem; top: 50%;
    transform: translateY(-50%);
    background: none; border: none;
    color: var(--muted); cursor: pointer;
    padding: 0.25rem; transition: color 0.2s;
}
.password-toggle:hover { color: var(--text); }

.success-state { text-align: center; }
.success-icon {
    width: 72px; height: 72px; border-radius: 50%;
    background: rgba(52,211,153,0.1);
    border: 1px solid rgba(52,211,153,0.2);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 1.5rem;
}
</style>
}

<div class="auth-wrap">
    <div class="auth-box">
        @if (Model.ResetSuccess)
        {
            <div class="card">
                <div class="success-state">
                    <div class="success-icon">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--success)" stroke-width="2">
                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                            <polyline points="22 4 12 14.01 9 11.01"/>
                        </svg>
                    </div>
                    <div class="auth-title" style="font-size:1.5rem">Пароль изменён!</div>
                    <p class="auth-sub mt-2">Теперь вы можете войти с новым паролем</p>
                    <a asp-page="/Auth/Login" class="btn btn-primary mt-4">Войти →</a>
                </div>
            </div>
        }
        else
        {
            <div style="margin-bottom:2rem">
                <div class="auth-title">Новый пароль</div>
                <div class="auth-sub">
                    Введите код из письма и придумайте новый пароль
                    @if (!string.IsNullOrEmpty(Model.Email))
                    {
                        <br/><span style="color:var(--accent)">@Model.Email</span>
                    }
                </div>
            </div>

            <div class="card">
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                        @Model.ErrorMessage
                    </div>
                }

                <form method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Input.Email" />

                    @* Email — если не передан через route *@
                    @if (string.IsNullOrEmpty(Model.Email))
                    {
                        <div class="form-group">
                            <label class="form-label">Email</label>
                            <input asp-for="Input.Email"
                                   class="form-control"
                                   type="email" placeholder="you@example.com" />
                            <span asp-validation-for="Input.Email" class="field-error"></span>
                        </div>
                    }

                    <div class="form-group">
                        <label class="form-label" style="text-align:center; display:block">Код подтверждения</label>
                        <div class="code-inputs" id="codeInputs">
                            @for (int i = 0; i < 6; i++)
                            {
                                <input type="text" maxlength="1" class="code-digit"
                                       data-index="@i" inputmode="numeric" />
                            }
                        </div>
                        <input type="hidden" asp-for="Input.ResetCode" id="codeHidden" />
                        <span asp-validation-for="Input.ResetCode" class="field-error" style="text-align:center; display:block"></span>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Новый пароль</label>
                        <div class="password-wrapper">
                            <input asp-for="Input.NewPassword"
                                   id="newPwd"
                                   class="form-control"
                                   type="password" placeholder="Минимум 6 символов"
                                   style="padding-right:2.75rem" />
                            <button type="button" class="password-toggle" onclick="togglePwd('newPwd', this)">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                    <circle cx="12" cy="12" r="3"/>
                                </svg>
                            </button>
                        </div>
                        <span asp-validation-for="Input.NewPassword" class="field-error"></span>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Подтверждение пароля</label>
                        <div class="password-wrapper">
                            <input asp-for="Input.ConfirmNewPassword"
                                   id="confirmPwd"
                                   class="form-control"
                                   type="password" placeholder="Повторите пароль"
                                   style="padding-right:2.75rem" />
                            <button type="button" class="password-toggle" onclick="togglePwd('confirmPwd', this)">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                    <circle cx="12" cy="12" r="3"/>
                                </svg>
                            </button>
                        </div>
                        <span asp-validation-for="Input.ConfirmNewPassword" class="field-error"></span>
                    </div>

                    <button type="submit" class="btn btn-primary mt-2" id="submitBtn">
                        <span class="spinner"></span>
                        <span class="btn-text">Сменить пароль</span>
                    </button>
                </form>

                <div class="text-center mt-3">
                    <a asp-page="/Auth/ForgotPassword" class="text-sm text-muted"
                       style="text-decoration:none; transition:color 0.2s"
                       onmouseover="this.style.color='var(--accent)'"
                       onmouseout="this.style.color='var(--muted)'">
                        ← Запросить новый код
                    </a>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
// Умный ввод кода — автопереход между полями
const digits = document.querySelectorAll('.code-digit');
const hidden  = document.getElementById('codeHidden');

digits.forEach((input, idx) => {
    input.addEventListener('input', e => {
        const val = e.target.value.replace(/\D/g, '');
        e.target.value = val;
        if (val) e.target.classList.add('filled');
        else      e.target.classList.remove('filled');

        if (val && idx < digits.length - 1) digits[idx + 1].focus();
        updateHidden();
    });

    input.addEventListener('keydown', e => {
        if (e.key === 'Backspace' && !input.value && idx > 0) {
            digits[idx - 1].focus();
            digits[idx - 1].value = '';
            digits[idx - 1].classList.remove('filled');
            updateHidden();
        }
    });

    input.addEventListener('paste', e => {
        e.preventDefault();
        const text = e.clipboardData.getData('text').replace(/\D/g, '').slice(0, 6);
        text.split('').forEach((ch, i) => {
            if (digits[i]) { digits[i].value = ch; digits[i].classList.add('filled'); }
        });
        if (digits[text.length]) digits[text.length].focus();
        updateHidden();
    });
});

function updateHidden() {
    hidden.value = [...digits].map(d => d.value).join('');
}

function togglePwd(id, btn) {
    const f = document.getElementById(id);
    f.type = f.type === 'password' ? 'text' : 'password';
    btn.querySelector('svg').innerHTML = f.type === 'text'
        ? '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>'
        : '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
}

document.querySelector('form')?.addEventListener('submit', function() {
    const btn = document.getElementById('submitBtn');
    btn.classList.add('loading'); btn.disabled = true;
});
</script>
}
