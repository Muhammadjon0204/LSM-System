@page
@model RazorPages.Pages.Auth.ForgotPasswordModel
@{
    ViewData["Title"] = "Забыли пароль?";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

@section Styles {
<style>
.auth-wrap {
    min-height: calc(100vh - var(--nav-h) - 80px);
    display: flex; align-items: center; justify-content: center;
}
.auth-box { width: 100%; max-width: 420px; }
.auth-title {
    font-family: var(--font-head);
    font-size: 1.85rem; font-weight: 800;
    letter-spacing: -0.04em; margin-bottom: 0.4rem;
}
.auth-sub { color: var(--muted); font-size: 0.9rem; }
.icon-wrap {
    width: 56px; height: 56px;
    border-radius: 14px;
    background: rgba(108,99,255,0.1);
    border: 1px solid rgba(108,99,255,0.2);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 1.25rem;
}
.success-state { text-align: center; padding: 0.5rem 0; }
.success-icon {
    width: 64px; height: 64px;
    border-radius: 50%;
    background: rgba(52,211,153,0.1);
    border: 1px solid rgba(52,211,153,0.2);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 1.25rem;
}
</style>
}

<div class="auth-wrap">
    <div class="auth-box">
        @if (Model.EmailSent)
        {
            <div class="card">
                <div class="success-state">
                    <div class="success-icon">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--success)" stroke-width="2">
                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                            <polyline points="22 4 12 14.01 9 11.01"/>
                        </svg>
                    </div>
                    <div class="auth-title" style="font-size:1.5rem">Проверьте почту</div>
                    <p class="auth-sub mt-2" style="line-height:1.6">
                        Если аккаунт с адресом <strong style="color:var(--text)">@Model.SentToEmail</strong> существует,
                        мы отправили код для сброса пароля.<br/>
                        Код действителен <strong style="color:var(--text)">2 минуты</strong>.
                    </p>
                    <a asp-page="/Auth/ResetPassword"
                       asp-route-email="@Model.SentToEmail"
                       class="btn btn-primary mt-4">
                        Ввести код →
                    </a>
                    <div class="mt-3">
                        <a asp-page="/Auth/ForgotPassword" class="text-sm text-muted"
                           style="text-decoration:none; transition:color 0.2s"
                           onmouseover="this.style.color='var(--accent)'"
                           onmouseout="this.style.color='var(--muted)'">
                            Отправить повторно
                        </a>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div style="text-align:center; margin-bottom:2rem">
                <div class="icon-wrap">
                    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                </div>
                <div class="auth-title">Сброс пароля</div>
                <div class="auth-sub">Введите email — пришлём код подтверждения</div>
            </div>

            <div class="card">
                <form method="post">
                    @Html.AntiForgeryToken()

                    <div class="form-group">
                        <label class="form-label">Email адрес</label>
                        <input asp-for="Input.Email"
                               class="form-control @(ViewData.ModelState["Input.Email"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               type="email"
                               placeholder="you@example.com"
                               autocomplete="email" />
                        <span asp-validation-for="Input.Email" class="field-error"></span>
                    </div>

                    <button type="submit" class="btn btn-primary mt-2" id="submitBtn">
                        <span class="spinner"></span>
                        <span class="btn-text">Отправить код</span>
                    </button>
                </form>

                <div class="text-center mt-3">
                    <a asp-page="/Auth/Login" class="text-sm text-muted"
                       style="text-decoration:none; transition:color 0.2s"
                       onmouseover="this.style.color='var(--accent)'"
                       onmouseout="this.style.color='var(--muted)'">
                        ← Назад к входу
                    </a>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
document.querySelector('form')?.addEventListener('submit', function() {
    const btn = document.getElementById('submitBtn');
    if (btn) { btn.classList.add('loading'); btn.disabled = true; }
});
</script>
}
