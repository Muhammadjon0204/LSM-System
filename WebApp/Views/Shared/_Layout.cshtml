<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] — EduPlatform</title>
    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
    <link rel="stylesheet" href="~/css/home.css">

    <link
        href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap"
        rel="stylesheet"/>
    @RenderSection("Styles", required: false)
</head>
<body>
<nav>
    <a class="nav-brand" asp-controller="Courses" asp-action="Index">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M12 2L2 7l10 5 10-5-10-5z"/>
            <path d="M2 17l10 5 10-5"/>
            <path d="M2 12l10 5 10-5"/>
        </svg>
        Edu<span>Platform</span>
    </a>

    <div class="nav-links">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a class="nav-link" asp-controller="Courses" asp-action="Index">Курсы</a>

            @if (User.IsInRole("Student"))
            {
                <a class="nav-link" asp-controller="Student" asp-action="MyCourses">Мои курсы</a>
            }

            @if (User.IsInRole("Instructor"))
            {
                <a class="nav-link" asp-controller="Instructor" asp-action="Index">
                    Мои курсы <span class="nav-badge green">Instructor</span>
                </a>
            }

            @if (User.IsInRole("Admin"))
            {
                <a class="nav-link" asp-controller="Admin" asp-action="Index">
                    Панель <span class="nav-badge">Admin</span>
                </a>
            }

            <span class="nav-link text-muted" style="cursor:default">
                @(User.FindFirst("FullName")?.Value ?? User.Identity!.Name)
            </span>

            <form asp-controller="Auth" asp-action="Logout" method="post" style="display:inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="nav-btn nav-btn-outline">Выйти</button>
            </form>
        }
        else
        {
            <a class="nav-link" asp-controller="Auth" asp-action="Login">Войти</a>
            <a class="nav-btn nav-btn-primary" asp-controller="Auth" asp-action="Register">Регистрация</a>
        }
    </div>
</nav>

<main>
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" y1="8" x2="12" y2="12"/>
                <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            @TempData["Error"]
        </div>
    }
    @if (TempData["Info"] != null)
    {
        <div class="alert alert-info">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" y1="8" x2="12" y2="12"/>
                <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            @TempData["Info"]
        </div>
    }
    @RenderBody()
</main>

<footer>
    <span>© 2025 EduPlatform</span>
    <span>Все права защищены</span>
</footer>

@RenderSection("Scripts", required: false)
</body>
</html>
