@page
@model RazorPages.Pages.Auth.LoginModel
@{
    ViewData["Title"] = "Вход";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

@section Styles {
<style>
.auth-wrap {
    min-height: calc(100vh - var(--nav-h) - 80px);
    display: flex;
    align-items: center;
    justify-content: center;
}

.auth-box {
    width: 100%;
    max-width: 420px;
}

.auth-header {
    text-align: center;
    margin-bottom: 2rem;
}

.auth-title {
    font-family: var(--font-head);
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.04em;
    margin-bottom: 0.4rem;
}

.auth-sub {
    color: var(--muted);
    font-size: 0.9rem;
}

.divider {
    display: flex; align-items: center; gap: 1rem;
    color: var(--muted); font-size: 0.8rem;
    margin: 1.25rem 0;
}

.divider::before, .divider::after {
    content: ''; flex: 1;
    height: 1px; background: var(--border);
}

.password-wrapper {
    position: relative;
}

.password-toggle {
    position: absolute; right: 0.75rem; top: 50%;
    transform: translateY(-50%);
    background: none; border: none;
    color: var(--muted); cursor: pointer;
    padding: 0.25rem;
    transition: color 0.2s;
}

.password-toggle:hover { color: var(--text); }
</style>
}

<div class="auth-wrap">
    <div class="auth-box">
        <div class="auth-header">
            <div class="auth-title">С возвращением 👋</div>
            <div class="auth-sub">Войдите в свой аккаунт</div>
        </div>

        <div class="card">
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    @Model.ErrorMessage
                </div>
            }

            <form method="post">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label class="form-label">Email</label>
                    <input asp-for="Input.Email"
                           class="form-control @(ViewData.ModelState["Input.Email"]?.Errors.Count > 0 ? "is-invalid" : "")"
                           type="email"
                           placeholder="you@example.com"
                           autocomplete="email" />
                    <span asp-validation-for="Input.Email" class="field-error"></span>
                </div>

                <div class="form-group">
                    <div class="d-flex justify-between align-center mb-1">
                        <label class="form-label" style="margin-bottom:0">Пароль</label>
                        <a asp-page="/Auth/ForgotPassword" class="text-sm text-muted" style="text-decoration:none; transition:color 0.2s"
                           onmouseover="this.style.color='var(--accent)'"
                           onmouseout="this.style.color='var(--muted)'">
                            Забыли пароль?
                        </a>
                    </div>
                    <div class="password-wrapper">
                        <input asp-for="Input.Password"
                               id="passwordField"
                               class="form-control @(ViewData.ModelState["Input.Password"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               type="password"
                               placeholder="••••••••"
                               autocomplete="current-password"
                               style="padding-right: 2.75rem" />
                        <button type="button" class="password-toggle" onclick="togglePassword()">
                            <svg id="eyeIcon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                <circle cx="12" cy="12" r="3"/>
                            </svg>
                        </button>
                    </div>
                    <span asp-validation-for="Input.Password" class="field-error"></span>
                </div>

                <button type="submit" class="btn btn-primary mt-2" id="submitBtn">
                    <span class="spinner"></span>
                    <span class="btn-text">Войти</span>
                </button>
            </form>

            <div class="divider">или</div>

            <div class="text-center text-sm text-muted">
                Нет аккаунта?
                <a asp-page="/Auth/Register" class="text-accent" style="text-decoration:none; font-weight:500">
                    Зарегистрироваться
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function togglePassword() {
    const field = document.getElementById('passwordField');
    const icon  = document.getElementById('eyeIcon');
    if (field.type === 'password') {
        field.type = 'text';
        icon.innerHTML = '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>';
    } else {
        field.type = 'password';
        icon.innerHTML = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
    }
}

document.querySelector('form').addEventListener('submit', function() {
    const btn = document.getElementById('submitBtn');
    btn.classList.add('loading');
    btn.disabled = true;
});
</script>
}
