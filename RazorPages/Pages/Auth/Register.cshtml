@page
@model RazorPages.Pages.Auth.RegisterModel
@{
    ViewData["Title"] = "Регистрация";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

@section Styles {
<style>
.auth-wrap {
    min-height: calc(100vh - var(--nav-h) - 80px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem 0;
}

.auth-box {
    width: 100%;
    max-width: 440px;
}

.auth-header {
    text-align: center;
    margin-bottom: 2rem;
}

.auth-title {
    font-family: var(--font-head);
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.04em;
    margin-bottom: 0.4rem;
}

.auth-sub { color: var(--muted); font-size: 0.9rem; }

.password-wrapper { position: relative; }

.password-toggle {
    position: absolute; right: 0.75rem; top: 50%;
    transform: translateY(-50%);
    background: none; border: none;
    color: var(--muted); cursor: pointer;
    padding: 0.25rem; transition: color 0.2s;
}
.password-toggle:hover { color: var(--text); }

.strength-bar {
    height: 3px;
    background: var(--border);
    border-radius: 99px;
    margin-top: 0.5rem;
    overflow: hidden;
}

.strength-fill {
    height: 100%;
    border-radius: 99px;
    transition: width 0.3s, background 0.3s;
    width: 0;
}

.role-note {
    display: flex; align-items: center; gap: 0.6rem;
    padding: 0.75rem 1rem;
    background: rgba(108,99,255,0.06);
    border: 1px solid rgba(108,99,255,0.15);
    border-radius: 8px;
    font-size: 0.82rem;
    color: var(--muted);
    margin-top: 1.25rem;
}

.divider {
    display: flex; align-items: center; gap: 1rem;
    color: var(--muted); font-size: 0.8rem;
    margin: 1.25rem 0;
}
.divider::before, .divider::after {
    content: ''; flex: 1;
    height: 1px; background: var(--border);
}
</style>
}

<div class="auth-wrap">
    <div class="auth-box">
        <div class="auth-header">
            <div class="auth-title">Создать аккаунт</div>
            <div class="auth-sub">Присоединяйтесь и начните учиться</div>
        </div>

        <div class="card">
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    @Model.ErrorMessage
                </div>
            }

            <form method="post">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label class="form-label">Полное имя</label>
                    <input asp-for="Input.FullName"
                           class="form-control @(ViewData.ModelState["Input.FullName"]?.Errors.Count > 0 ? "is-invalid" : "")"
                           type="text"
                           placeholder="Иван Петров"
                           autocomplete="name" />
                    <span asp-validation-for="Input.FullName" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Email</label>
                    <input asp-for="Input.Email"
                           class="form-control @(ViewData.ModelState["Input.Email"]?.Errors.Count > 0 ? "is-invalid" : "")"
                           type="email"
                           placeholder="you@example.com"
                           autocomplete="email" />
                    <span asp-validation-for="Input.Email" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Пароль</label>
                    <div class="password-wrapper">
                        <input asp-for="Input.Password"
                               id="passwordField"
                               class="form-control @(ViewData.ModelState["Input.Password"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               type="password"
                               placeholder="Минимум 6 символов"
                               autocomplete="new-password"
                               style="padding-right: 2.75rem"
                               oninput="checkStrength(this.value)" />
                        <button type="button" class="password-toggle" onclick="togglePwd('passwordField', this)">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                <circle cx="12" cy="12" r="3"/>
                            </svg>
                        </button>
                    </div>
                    <div class="strength-bar"><div class="strength-fill" id="strengthFill"></div></div>
                    <span asp-validation-for="Input.Password" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Подтверждение пароля</label>
                    <div class="password-wrapper">
                        <input asp-for="Input.ConfirmPassword"
                               id="confirmField"
                               class="form-control @(ViewData.ModelState["Input.ConfirmPassword"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               type="password"
                               placeholder="Повторите пароль"
                               autocomplete="new-password"
                               style="padding-right: 2.75rem" />
                        <button type="button" class="password-toggle" onclick="togglePwd('confirmField', this)">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                <circle cx="12" cy="12" r="3"/>
                            </svg>
                        </button>
                    </div>
                    <span asp-validation-for="Input.ConfirmPassword" class="field-error"></span>
                </div>

                <div class="role-note">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    После регистрации вы получите роль <strong style="color:var(--text)">Студента</strong> и сможете записываться на курсы
                </div>

                <button type="submit" class="btn btn-primary mt-3" id="submitBtn">
                    <span class="spinner"></span>
                    <span class="btn-text">Создать аккаунт</span>
                </button>
            </form>

            <div class="divider" style="margin-top:1.5rem">или</div>

            <div class="text-center text-sm text-muted">
                Уже есть аккаунт?
                <a asp-page="/Auth/Login" class="text-accent" style="text-decoration:none; font-weight:500">
                    Войти
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function togglePwd(fieldId, btn) {
    const field = document.getElementById(fieldId);
    const isHidden = field.type === 'password';
    field.type = isHidden ? 'text' : 'password';
    btn.querySelector('svg').innerHTML = isHidden
        ? '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>'
        : '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
}

function checkStrength(val) {
    const fill = document.getElementById('strengthFill');
    let score = 0;
    if (val.length >= 6)  score++;
    if (val.length >= 10) score++;
    if (/[A-Z]/.test(val)) score++;
    if (/[0-9]/.test(val)) score++;
    if (/[^A-Za-z0-9]/.test(val)) score++;

    const pct    = (score / 5) * 100;
    const colors = ['#f87171','#fb923c','#facc15','#34d399','#6c63ff'];
    fill.style.width      = pct + '%';
    fill.style.background = colors[Math.max(0, score - 1)] || 'transparent';
}

document.querySelector('form').addEventListener('submit', function() {
    const btn = document.getElementById('submitBtn');
    btn.classList.add('loading');
    btn.disabled = true;
});
</script>
}
